{
	"linter": {
		"enabled": true
	},
	"overrides": [
		{
			"includes": ["src/capabilities/core/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"@openai/agents": "capabilities/core must not depend on OpenAI Agents SDK."
								},
								"patterns": [
									{
										"group": ["**/adapters/**"],
										"message": "capabilities/core must not import adapters."
									},
									{
										"group": ["node:*"],
										"message": "capabilities/core must remain runtime-agnostic."
									}
								]
							}
						}
					}
				}
			}
		}
	]
}
