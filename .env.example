PORT=3000
LANGUAGE=English

# Slack
# Choose exactly one mode:
# 1. HTTP mode: keep SLACK_SOCKET_MODE=false and set SLACK_SIGNING_SECRET
# 2. Socket Mode: set SLACK_SOCKET_MODE=true and set SLACK_APP_TOKEN instead
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SOCKET_MODE=false
SLACK_SIGNING_SECRET=your-slack-signing-secret
# SLACK_SOCKET_MODE=true
# SLACK_APP_TOKEN=xapp-your-app-level-token

# Datadog
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# LLM provider
# OpenAI example:
LLM_PROVIDER=openai
LLM_OPENAI_API_KEY=sk-your-openai-api-key

# Bedrock example:
# LLM_PROVIDER=bedrock
# LLM_BEDROCK_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0
# AWS credentials and region are loaded from the standard AWS environment or profile chain.
# AWS_PROFILE=your-aws-profile
# AWS_REGION=ap-northeast-1

# Vertex AI example:
# Google credentials are loaded from Application Default Credentials.
# LLM_PROVIDER=vertexai
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-east5
# LLM_VERTEX_AI_MODEL_ID=claude-sonnet-4-6@20260218

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_SEARCH_SCOPE_ORG=your-github-org
