# Secrets referenced from reili.toml
# Copy config/default.toml to ./reili.toml and adjust non-secret settings there.

# Slack credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# Datadog credentials
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# OpenAI backend credentials
LLM_OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic backend credentials
# LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Bedrock uses the standard AWS credential chain.

# Vertex AI uses Application Default Credentials; no secret env vars are required here.

# GitHub App private key
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Optional esa connector credentials
# ESA_ACCESS_TOKEN=your-esa-access-token
