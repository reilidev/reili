{
  "name": "sre-mate",
  "version": "1.0.0",
  "description": "",
  "main": "dist/runtime/ingress/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:ingress": "nodemon --watch src --ext ts --exec \"tsx --env-file=.env src/runtime/ingress/index.ts\"",
    "dev:worker": "mkdir -p .tmp && nodemon --watch src --ext ts --exec \"sh -c 'tsx --env-file=.env src/runtime/worker/index.ts 2>&1 | tee .tmp/log.txt'\"",
    "dev:test": "vitest",
    "test": "vitest run",
    "start:ingress": "tsx src/runtime/ingress/index.ts",
    "start:worker": "tsx src/runtime/worker/index.ts",
    "dev": "pnpm dev:ingress",
    "start": "pnpm start:ingress",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write src",
    "lint:deps": "depcruise --config .dependency-cruiser.js src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@datadog/datadog-api-client": "1.52.0",
    "@octokit/auth-app": "8.2.0",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@octokit/request-error": "7.1.0",
    "@octokit/rest": "22.0.1",
    "@openai/agents": "0.4.14",
    "@slack/bolt": "4.6.0",
    "express": "5.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@types/express": "5.0.6",
    "@types/node": "24.4.0",
    "dependency-cruiser": "17.3.8",
    "nodemon": "3.1.13",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
